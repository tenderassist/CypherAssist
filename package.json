{
  "name": "cypher-assist",
  "version": "3.1.0",
  "private": true,
  "description": "CypherAssist frontend",
  "source": [
    "index.html",
    "login.html",
    "addbox.html",
    "addoffice.html",
    "boxin.html",
    "boxout.html",
    "boxsummary.html",
    "officesummary.html",
    "outstanding.html",
    "reset.html",
    "searchbox.html"
  ],
  "alias": {
    "process": "process/browser"
  },
  "scripts": {
    "dev": "parcel serve index.html",
    "build": "parcel build index.html login.html addbox.html addoffice.html boxin.html boxout.html boxsummary.html officesummary.html outstanding.html reset.html searchbox.html --no-source-maps"
  },
  "devDependencies": {
    "firebase": "^10.12.5",
    "parcel": "^2.14.4"
  },
  "dependencies": {
    "process": "^0.11.10"
  }
}
